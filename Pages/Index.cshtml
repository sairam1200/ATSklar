@page
@model IndexModel
@{
    ViewData["Title"] = "ATSklar";
}

<style>
    :root {
        --bg: #f6f1e8;
        --paper: rgba(255, 252, 245, 0.82);
        --ink: #14213d;
        --muted: #5c6473;
        --line: rgba(20, 33, 61, 0.12);
        --brand: #0f766e;
        --brand-dark: #115e59;
        --accent: #d97706;
    }

    body {
        background:
            radial-gradient(circle at top left, rgba(15, 118, 110, 0.12), transparent 24%),
            radial-gradient(circle at bottom right, rgba(217, 119, 6, 0.10), transparent 22%),
            var(--bg);
        color: var(--ink);
        font-family: Georgia, Cambria, "Times New Roman", serif;
    }

    .home-wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 3.5rem 1.25rem 4rem;
    }

    .hero {
        background: var(--paper);
        backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.7);
        border-radius: 36px;
        box-shadow: 0 24px 56px rgba(20, 33, 61, 0.08);
        padding: 3rem;
    }

    .eyebrow {
        display: inline-block;
        padding: 0.45rem 0.8rem;
        border-radius: 999px;
        background: rgba(15, 118, 110, 0.10);
        color: var(--brand-dark);
        font: 700 0.78rem/1 "Segoe UI", sans-serif;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    h1 {
        margin: 1rem 0 0.85rem;
        font-size: clamp(3rem, 7vw, 5.8rem);
        line-height: 0.92;
        letter-spacing: -0.05em;
        max-width: 9ch;
    }

    .lead {
        max-width: 54ch;
        margin: 0;
        color: var(--muted);
        font: 500 1.02rem/1.75 "Segoe UI", sans-serif;
    }

    .picker {
        margin-top: 2rem;
    }

    .picker-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .picker-head p {
        margin: 0;
        color: var(--muted);
        font: 600 0.9rem/1.5 "Segoe UI", sans-serif;
    }

    .path-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .path-card {
        position: relative;
        display: block;
        background: rgba(255, 255, 255, 0.72);
        border: 1px solid var(--line);
        border-radius: 26px;
        padding: 1.35rem;
        text-decoration: none;
        color: inherit;
        overflow: hidden;
        transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease, background .22s ease;
    }

    .path-card:hover,
    .path-card:focus-visible {
        transform: translateY(-4px);
        border-color: rgba(15, 118, 110, 0.35);
        box-shadow: 0 18px 34px rgba(20, 33, 61, 0.10);
        background: rgba(255, 255, 255, 0.9);
        outline: none;
    }

    .path-card.active {
        border-color: rgba(15, 118, 110, 0.5);
        background: linear-gradient(180deg, rgba(15, 118, 110, 0.08), rgba(255, 255, 255, 0.92));
        box-shadow: 0 20px 36px rgba(17, 94, 89, 0.12);
    }

    .path-card::after {
        content: "";
        position: absolute;
        inset: auto -22px -22px auto;
        width: 90px;
        height: 90px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(217, 119, 6, 0.12), transparent 70%);
        opacity: 0;
        transition: opacity .22s ease;
    }

    .path-card:hover::after,
    .path-card.active::after {
        opacity: 1;
    }

    .path-card small {
        display: block;
        margin-bottom: 0.5rem;
        color: var(--accent);
        font: 700 0.76rem/1 "Segoe UI", sans-serif;
        letter-spacing: 0.08em;
        text-transform: uppercase;
    }

    .path-card h2 {
        margin: 0 0 0.45rem;
        font-size: 1.35rem;
    }

    .path-card p {
        margin: 0;
        color: var(--muted);
        font: 500 0.95rem/1.7 "Segoe UI", sans-serif;
    }

    .path-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-top: 1rem;
    }

    .path-badge {
        display: inline-flex;
        align-items: center;
        padding: 0.45rem 0.72rem;
        border-radius: 999px;
        background: rgba(20, 33, 61, 0.06);
        color: var(--ink);
        font: 700 0.77rem/1 "Segoe UI", sans-serif;
        letter-spacing: 0.04em;
        text-transform: uppercase;
    }

    .path-arrow {
        font: 700 1rem/1 "Segoe UI", sans-serif;
        color: var(--brand-dark);
        transition: transform .22s ease;
    }

    .path-card:hover .path-arrow,
    .path-card.active .path-arrow {
        transform: translateX(4px);
    }

    .actions {
        display: flex;
        gap: 0.85rem;
        flex-wrap: wrap;
        margin-top: 1.5rem;
    }

    .btn-main,
    .btn-ghost {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-width: 170px;
        padding: 0.95rem 1.25rem;
        border-radius: 999px;
        text-decoration: none;
        font: 700 0.94rem/1 "Segoe UI", sans-serif;
        transition: transform .22s ease, box-shadow .22s ease, background .22s ease;
    }

    .btn-main:hover,
    .btn-ghost:hover {
        transform: translateY(-2px);
    }

    .btn-main {
        color: white;
        background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
        box-shadow: 0 16px 32px rgba(17, 94, 89, 0.20);
    }

    .btn-ghost {
        color: var(--ink);
        background: transparent;
        border: 1px solid var(--line);
    }

    .mode-panel {
        margin-top: 1.25rem;
        padding: 1rem 1.05rem;
        border-radius: 22px;
        background: rgba(255, 255, 255, 0.64);
        border: 1px solid var(--line);
    }

    .mode-panel strong {
        display: block;
        margin-bottom: 0.35rem;
        font: 700 0.92rem/1.4 "Segoe UI", sans-serif;
        color: var(--ink);
    }

    .mode-panel p {
        margin: 0;
        color: var(--muted);
        font: 500 0.92rem/1.7 "Segoe UI", sans-serif;
    }

    .note {
        margin-top: 1.25rem;
        color: var(--muted);
        font: 500 0.9rem/1.7 "Segoe UI", sans-serif;
    }

    @@media (max-width: 860px) {
        .hero {
            padding: 2rem 1.4rem;
        }

        .path-grid {
            grid-template-columns: 1fr;
        }

        .picker-head {
            align-items: flex-start;
            flex-direction: column;
        }
    }
</style>

<div class="home-wrap">
    <section class="hero">
        <span class="eyebrow">Resume Check</span>
        <h1>Upload your resume and get clear ATS checks.</h1>
        <p class="lead">
            Choose a simple upload flow, then review the steps your resume passes or fails.
        </p>

        <div class="picker">
            <div class="picker-head">
                <p>Choose your mode</p>
            </div>

            <div class="path-grid">
                <a class="path-card active" asp-page="/ResumeModifier" asp-route-mode="quick" data-mode="quick" aria-label="Open quick mode">
                    <small>Quick</small>
                    <h2>Quick check</h2>
                    <p>Upload your resume and review the main ATS checks.</p>
                    <div class="path-meta">
                        <span class="path-badge">Fast start</span>
                        <span class="path-arrow">→</span>
                    </div>
                </a>

                <a class="path-card" asp-page="/ResumeModifier" asp-route-mode="focused" data-mode="focused" aria-label="Open focused mode">
                    <small>Focused</small>
                    <h2>Targeted check</h2>
                    <p>Add job details to get extra keyword suggestions and placement tips.</p>
                    <div class="path-meta">
                        <span class="path-badge">Best match</span>
                        <span class="path-arrow">→</span>
                    </div>
                </a>
            </div>

            <div class="mode-panel" id="modePanel">
                <strong>Quick check</strong>
                <p>Upload your resume, run the ATS checks, and review the results.</p>
            </div>
        </div>

        <div class="actions">
            <a class="btn-main" id="primaryAction" asp-page="/ResumeModifier" asp-route-mode="quick">Start Quick Check</a>
            <a class="btn-ghost" asp-page="/Privacy">Privacy</a>
        </div>

        <p class="note">Simple upload. Clear steps. Easy review.</p>
    </section>
</div>

<script>
    (() => {
        const cards = document.querySelectorAll('.path-card');
        const modePanel = document.getElementById('modePanel');
        const primaryAction = document.getElementById('primaryAction');

        const modes = {
            quick: {
                title: 'Quick check',
                body: 'Upload your resume, run the ATS checks, and review the results.',
                cta: 'Start Quick Check',
                href: '/ResumeModifier/quick'
            },
            focused: {
                title: 'Targeted check',
                body: 'Add job details to get extra keyword suggestions and placement tips.',
                cta: 'Start Targeted Check',
                href: '/ResumeModifier/focused'
            }
        };

        cards.forEach(card => {
            card.addEventListener('mouseenter', () => setMode(card.dataset.mode));
            card.addEventListener('focus', () => setMode(card.dataset.mode));
            card.addEventListener('click', () => setMode(card.dataset.mode));
        });

        function setMode(mode) {
            const config = modes[mode] || modes.quick;

            cards.forEach(card => {
                card.classList.toggle('active', card.dataset.mode === mode);
            });

            modePanel.innerHTML = `<strong>${config.title}</strong><p>${config.body}</p>`;
            primaryAction.textContent = config.cta;
            primaryAction.setAttribute('href', config.href);
        }
    })();
</script>
