@page "{mode?}"
@model ResumeModifierModel
@{
    ViewData["Title"] = "ATS Resume Optimizer";
    var isFocusedMode = string.Equals(Model.Mode, "focused", StringComparison.OrdinalIgnoreCase);
}

@functions {
    private string ScoreTone(int score) => score switch
    {
        >= 85 => "score-strong",
        >= 65 => "score-good",
        >= 45 => "score-watch",
        _ => "score-risk"
    };

    private string StepStatusTone(string status) => status switch
    {
        "Great" => "step-status step-status-great",
        "Watch" => "step-status step-status-watch",
        "Risk" => "step-status step-status-risk",
        _ => "step-status step-status-watch"
    };
}

<style>
    :root {
        --ink: #132238;
        --muted: #5b6b80;
        --line: #d9e1ea;
        --surface: rgba(255,255,255,0.84);
        --white: #ffffff;
        --brand: #0f766e;
        --brand-dark: #115e59;
        --accent: #f97316;
        --good: #15803d;
        --warn: #c2410c;
        --bad: #b91c1c;
    }

    body {
        background:
            radial-gradient(circle at top left, rgba(15, 118, 110, 0.16), transparent 28%),
            radial-gradient(circle at top right, rgba(249, 115, 22, 0.13), transparent 22%),
            linear-gradient(180deg, #ecf4f3 0%, #f6f2ec 50%, #fbfaf7 100%);
        color: var(--ink);
        font-family: Georgia, Cambria, "Times New Roman", serif;
    }

    .resume-shell {
        max-width: 980px;
        margin: 0 auto;
        padding: 1.25rem 1rem 3rem;
    }

    .hero,
    .stats-grid,
    .dual-grid,
    .form-grid {
        display: grid;
        gap: 1rem;
    }

    .hero {
        grid-template-columns: 1fr;
        margin-bottom: .75rem;
    }

    .stats-grid,
    .dual-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .form-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .wide {
        grid-column: 1 / -1;
    }

    .glass,
    .panel {
        background: transparent;
        border: 0;
        box-shadow: none;
        backdrop-filter: none;
        border-radius: 0;
    }

    .hero-copy,
    .panel {
        padding: 0;
    }

    .hero-copy h1 {
        margin: .45rem 0 .35rem;
        font-size: clamp(1.8rem, 3.6vw, 2.8rem);
        line-height: 1.02;
        letter-spacing: -.04em;
    }

    .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: .45rem;
        padding: .45rem .85rem;
        border-radius: 999px;
        background: rgba(15,118,110,.12);
        color: var(--brand-dark);
        font: 700 .84rem/1 "Segoe UI", sans-serif;
        letter-spacing: .06em;
        text-transform: uppercase;
    }

    .body-copy,
    .panel li {
        color: var(--muted);
        font: 500 .96rem/1.65 "Segoe UI", sans-serif;
    }

    .chip-row {
        display: flex;
        flex-wrap: wrap;
        gap: .7rem;
        margin-top: .6rem;
    }

    .chip,
    .keyword-chip {
        display: inline-flex;
        align-items: center;
        padding: .55rem .88rem;
        border-radius: 999px;
        background: var(--white);
        border: 1px solid rgba(19,34,56,.08);
        font: 700 .88rem/1 "Segoe UI", sans-serif;
    }

    .panel-head {
        display: flex;
        justify-content: space-between;
        align-items: start;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .panel-head h2,
    .card-title {
        margin: 0;
        font-size: 1.3rem;
    }

    label {
        display: block;
        margin-bottom: .45rem;
        color: var(--ink);
        font: 700 .84rem/1.2 "Segoe UI", sans-serif;
        letter-spacing: .05em;
        text-transform: uppercase;
    }

    input[type="text"],
    input[type="file"],
    textarea {
        width: 100%;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: rgba(255,255,255,.92);
        padding: .95rem 1rem;
        color: var(--ink);
        font: 500 .98rem/1.45 "Segoe UI", sans-serif;
    }

    textarea {
        min-height: 160px;
        resize: vertical;
    }

    .upload-box,
    .info-card,
    .preview-box {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: 0;
    }

    .upload-box {
        background: transparent;
        max-width: 520px;
    }

    .upload-compact {
        display: grid;
        gap: .55rem;
        max-width: 520px;
    }

    .button-row {
        display: flex;
        flex-wrap: wrap;
        gap: .75rem;
        margin-top: .7rem;
    }

    .btn-main,
    .btn-soft {
        border: none;
        border-radius: 999px;
        padding: .9rem 1.3rem;
        font: 700 .94rem/1 "Segoe UI", sans-serif;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
    }

    .btn-main {
        color: white;
        background: linear-gradient(135deg, var(--brand) 0%, var(--brand-dark) 100%);
        box-shadow: 0 14px 28px rgba(17,94,89,.22);
    }

    .btn-soft {
        color: var(--ink);
        background: white;
        border: 1px solid var(--line);
    }

    .metric strong {
        display: block;
        margin-bottom: .35rem;
        font-size: 2rem;
        line-height: 1;
    }

    .score-strong strong { color: var(--good); }
    .score-good strong { color: var(--brand); }
    .score-watch strong { color: var(--warn); }
    .score-risk strong { color: var(--bad); }

    .preview-box {
        white-space: pre-wrap;
        max-height: 700px;
        overflow: auto;
        font: 500 .96rem/1.8 "Segoe UI", sans-serif;
        background: #fffdfa;
    }

    .notice {
        border-radius: 12px;
        padding: .95rem 1rem;
        margin-bottom: 1rem;
        font: 700 .92rem/1.5 "Segoe UI", sans-serif;
    }

    .notice-ok {
        background: rgba(21,128,61,.12);
        color: #166534;
    }

    .notice-bad {
        background: rgba(185,28,28,.12);
        color: #991b1b;
    }

    .mode-banner {
        margin-top: .6rem;
        padding: 0;
        border-radius: 0;
        background: transparent;
        border: 0;
    }

    .mode-banner strong {
        display: block;
        margin-bottom: .35rem;
        font: 700 .92rem/1.4 "Segoe UI", sans-serif;
    }

    .suggestion-list {
        display: grid;
        gap: .85rem;
    }

    .suggestion-card {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: .35rem 0;
        border-bottom: 1px solid rgba(19,34,56,.08);
    }

    .suggestion-card strong,
    .suggestion-card .live-location {
        display: block;
    }

    .live-location {
        margin: .35rem 0 .5rem;
        color: var(--brand-dark);
        font: 700 .82rem/1.4 "Segoe UI", sans-serif;
        letter-spacing: .04em;
        text-transform: uppercase;
    }

    .suggestion-card p {
        margin: 0 0 .55rem;
    }

    .subtle-note {
        margin-top: .45rem;
        color: var(--muted);
        font: 500 .9rem/1.6 "Segoe UI", sans-serif;
    }

    .step-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
    }

    .guide-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .guide-card {
        padding: .9rem 1rem;
        border-radius: 18px;
        background: rgba(255,255,255,.55);
        border: 1px solid rgba(19,34,56,.08);
    }

    .guide-card h2 {
        display: flex;
        align-items: center;
        gap: .5rem;
        margin-bottom: .75rem;
    }

    .guide-icon {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 1.8rem;
        height: 1.8rem;
        border-radius: 999px;
        background: rgba(15,118,110,.12);
        color: var(--brand-dark);
        font: 700 .9rem/1 "Segoe UI", sans-serif;
    }

    .flow-list,
    .outcome-list {
        display: grid;
        gap: .7rem;
    }

    .flow-item,
    .outcome-item {
        display: grid;
        grid-template-columns: auto 1fr;
        gap: .7rem;
        align-items: start;
    }

    .flow-badge {
        width: 1.8rem;
        height: 1.8rem;
        border-radius: 999px;
        background: rgba(20,33,61,.08);
        color: var(--ink);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font: 700 .82rem/1 "Segoe UI", sans-serif;
    }

    .outcome-dot {
        width: .9rem;
        height: .9rem;
        border-radius: 999px;
        margin-top: .35rem;
    }

    .outcome-dot-great {
        background: #15803d;
    }

    .outcome-dot-watch {
        background: #c2410c;
    }

    .outcome-dot-risk {
        background: #b91c1c;
    }

    .step-card {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: .5rem 0;
        border-bottom: 1px solid rgba(19,34,56,.08);
    }

    .step-meta {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: .55rem;
    }

    .step-status {
        padding: .35rem .65rem;
        border-radius: 999px;
        font: 700 .78rem/1 "Segoe UI", sans-serif;
        text-transform: uppercase;
        letter-spacing: .04em;
    }

    .step-status-great {
        background: rgba(21,128,61,.12);
        color: #166534;
    }

    .step-status-watch {
        background: rgba(194,65,12,.12);
        color: #9a3412;
    }

    .step-status-risk {
        background: rgba(185,28,28,.12);
        color: #991b1b;
    }

    .repetition-list {
        display: grid;
        gap: .75rem;
    }

    .repetition-item {
        background: transparent;
        border: 0;
        border-radius: 0;
        padding: .45rem 0;
        border-bottom: 1px solid rgba(19,34,56,.08);
    }

    @@media (max-width: 1100px) {
        .hero,
        .stats-grid,
        .dual-grid,
        .form-grid,
        .step-grid,
        .guide-grid {
            grid-template-columns: 1fr;
        }
    }
</style>

<div class="resume-shell">
    <section class="hero">
        <div class="hero-copy">
            <span class="eyebrow">Resume Check</span>
            <div class="mode-banner">
                <p class="body-copy">
                    @(isFocusedMode
                        ? "Targeted check with optional job details."
                        : "Quick check for ATS readability.")
                </p>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(Model.Message))
    {
        <div class="notice @(Model.IsSuccess ? "notice-ok" : "notice-bad")">@Model.Message</div>
    }

    <div style="display:grid; gap:1rem;">
        <main style="display:grid; gap:1rem;">
            <section class="glass panel">
                

                <form method="post" enctype="multipart/form-data">
                    <input asp-for="Mode" type="hidden" />
                    <div class="upload-box upload-compact">
                        <label asp-for="ResumeFile">Upload file</label>
                        <input asp-for="ResumeFile" type="file" accept=".pdf,.docx,.txt" />
                        <div class="body-copy" style="margin-top:.45rem;">PDF, DOCX, TXT up to 10MB.</div>
                    </div>
                    <div class="button-row">
                        <button class="btn-main" type="submit" name="action" value="analyze">Analyze Resume</button>
                    </div>
                </form>
            </section>

            <section class="panel">
                <div class="guide-grid">
                    <div class="guide-card">
                        <h2><span class="guide-icon">1</span> How It Works</h2>
                        <div class="flow-list body-copy">
                            <div class="flow-item">
                                <span class="flow-badge">1</span>
                                <div>Upload the resume file.</div>
                            </div>
                            <div class="flow-item">
                                <span class="flow-badge">2</span>
                                <div>The system reads text, sections, and contact details.</div>
                            </div>
                            <div class="flow-item">
                                <span class="flow-badge">3</span>
                                <div>It checks formatting, keywords, repetition, and impact.</div>
                            </div>
                            <div class="flow-item">
                                <span class="flow-badge">4</span>
                                <div>You get step-by-step ATS results and suggestions.</div>
                            </div>
                        </div>
                    </div>

                    <div class="guide-card">
                        <h2><span class="guide-icon">2</span> Outcomes</h2>
                        <div class="outcome-list body-copy">
                            <div class="outcome-item">
                                <span class="outcome-dot outcome-dot-great"></span>
                                <div><strong>Great</strong><br />Clear and ATS-friendly.</div>
                            </div>
                            <div class="outcome-item">
                                <span class="outcome-dot outcome-dot-watch"></span>
                                <div><strong>Watch</strong><br />Readable, but can be improved.</div>
                            </div>
                            <div class="outcome-item">
                                <span class="outcome-dot outcome-dot-risk"></span>
                                <div><strong>Risk</strong><br />May reduce parsing or matching.</div>
                            </div>
                            <div class="outcome-item">
                                <span class="outcome-dot outcome-dot-great"></span>
                                <div><strong>Extra</strong><br />Add job details for keyword suggestions.</div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            @if (Model.ResumeAnalyzed)
            {
                <section class="glass panel">
                        <div class="panel-head">
                            <div>
                            <h2>2. Add Job Details</h2>
                            <p class="body-copy">
                                @(isFocusedMode
                                    ? "Add the company, role, and job description for job-specific checks."
                                    : "This is optional, but it helps generate job-specific suggestions.")
                            </p>
                        </div>
                    </div>

                    <form method="post" id="targetingForm">
                        <input asp-for="Mode" type="hidden" />
                        <div class="form-grid">
                            <div>
                                <label asp-for="CompanyName">Target company</label>
                                <input asp-for="CompanyName" id="CompanyName" type="text" placeholder="Example: Amazon" />
                            </div>
                            <div>
                                <label asp-for="TargetRole">Target role</label>
                                <input asp-for="TargetRole" id="TargetRole" type="text" placeholder="Example: Data Analyst" />
                            </div>
                            <div class="wide">
                                <label asp-for="CompanyWebsite">Company website (optional)</label>
                                <input asp-for="CompanyWebsite" type="text" placeholder="Example: amazon.com or careers page URL" />
                            </div>
                            <div class="wide">
                                <label asp-for="JobDescription">Job description</label>
                                <textarea asp-for="JobDescription" id="JobDescription" placeholder="Paste the target job description for stronger ATS matching and better rewrite guidance."></textarea>
                            </div>
                        </div>

                        <div class="button-row">
                            <button class="btn-main" type="submit" name="action" value="researchOptimize">Run Job-Specific Check</button>
                        </div>
                    </form>
                </section>

                <section class="glass panel">
                    <div class="panel-head">
                        <div>
                            <h2>Check Summary</h2>
                            <p class="body-copy">A quick view of the current ATS readiness of the uploaded resume.</p>
                        </div>
                    </div>

                    <div class="stats-grid">
                        <div class="info-card metric @ScoreTone(Model.ATSScore)">
                            <strong>@Model.ATSScore</strong>
                            <div class="body-copy">ATS score</div>
                        </div>
                        <div class="info-card metric">
                            <strong>@Model.KeywordFrequency.Count</strong>
                            <div class="body-copy">Recognized keywords</div>
                        </div>
                    </div>
                </section>

                <section class="glass panel">
                        <div class="panel-head">
                            <div>
                            <h2>Issues And Gaps</h2>
                            <p class="body-copy">These are the main issues detected in the uploaded resume.</p>
                        </div>
                    </div>

                    <div class="dual-grid">
                        <div class="info-card">
                            <div class="card-title">ATS Issues</div>
                            <ul>
                                @if (Model.ATSIssues.Count == 0)
                                {
                                    <li>No major ATS issues detected.</li>
                                }
                                else
                                {
                                    @foreach (var issue in Model.ATSIssues)
                                    {
                                        <li><strong>@issue.Severity:</strong> @issue.Issue. @issue.Recommendation</li>
                                    }
                                }
                            </ul>
                        </div>

                        <div class="info-card">
                            <div class="card-title">Suggested Keywords</div>
                            <div class="chip-row">
                                @if (Model.MissingKeywords.Count == 0)
                                {
                                    <span class="keyword-chip">No large baseline gaps</span>
                                }
                                else
                                {
                                    @foreach (var keyword in Model.MissingKeywords.Take(12))
                                    {
                                        <span class="keyword-chip">@keyword</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                </section>

                <section class="glass panel">
                    <div class="panel-head">
                        <div>
                            <h2>ATS Verification Steps</h2>
                            <p class="body-copy">These are the steps the system checks during review.</p>
                        </div>
                    </div>

                    <div class="stats-grid">
                        <div class="info-card metric @(Model.ATSDetailedReport.TotalIssues == 0 ? "score-strong" : Model.ATSDetailedReport.TotalIssues <= 3 ? "score-watch" : "score-risk")">
                            <strong>@Model.ATSDetailedReport.TotalIssues</strong>
                            <div class="body-copy">Issues found</div>
                        </div>
                        <div class="info-card metric @ScoreTone(Model.ATSDetailedReport.ParseRate)">
                            <strong>@Model.ATSDetailedReport.ParseRate%</strong>
                            <div class="body-copy">Parse rate</div>
                        </div>
                    </div>

                    <div class="step-grid" style="margin-top:1rem;">
                        @foreach (var step in Model.ATSDetailedReport.Steps)
                        {
                            <div class="step-card">
                                <div class="step-meta">
                                    <div>
                                        <div class="card-title">@step.Title</div>
                                        <div class="subtle-note" style="margin-top:.25rem;">@step.Category</div>
                                    </div>
                                    <span class="@StepStatusTone(step.Status)">@step.Status</span>
                                </div>
                                <p class="body-copy">@step.Summary</p>
                                @if (step.Details.Count > 0)
                                {
                                    <ul>
                                        @foreach (var detail in step.Details)
                                        {
                                            <li>@detail</li>
                                        }
                                    </ul>
                                }
                            </div>
                        }
                    </div>

                    @if (Model.ATSDetailedReport.RepeatedWords.Count > 0)
                    {
                        <div style="margin-top:1rem;">
                            <div class="card-title">Repeated Words</div>
                            <div class="repetition-list" style="margin-top:.8rem;">
                                @foreach (var word in Model.ATSDetailedReport.RepeatedWords)
                                {
                                    <div class="repetition-item">
                                        <strong>@word.Count times: @word.Word</strong>
                                        @if (word.Alternatives.Count > 0)
                                        {
                                            <div class="chip-row">
                                                @foreach (var alternative in word.Alternatives)
                                                {
                                                    <span class="keyword-chip">@alternative</span>
                                                }
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </section>
            }

            @if (Model.JobAnalyzed && Model.JobKeywordAnalysis != null)
            {
                <section class="glass panel">
                    <div class="panel-head">
                        <div>
                            <h2>Job Match Snapshot</h2>
                            <p class="body-copy">Your resume compared with the job description.</p>
                        </div>
                    </div>

                    <div class="stats-grid">
                        <div class="info-card metric @ScoreTone(Model.JobKeywordAnalysis.MatchPercentage)">
                            <strong>@Model.JobKeywordAnalysis.MatchPercentage%</strong>
                            <div class="body-copy">Current job keyword match</div>
                        </div>
                        <div class="info-card metric">
                            <strong>@Model.JobKeywordAnalysis.MissingKeywordsFromJob.Count</strong>
                            <div class="body-copy">Missing job keywords</div>
                        </div>
                    </div>

                    @if (Model.PlacementSuggestions.Count > 0)
                    {
                        <div class="suggestion-list" style="margin-top:1rem;">
                            @foreach (var suggestion in Model.PlacementSuggestions)
                            {
                                <div class="suggestion-card">
                                    <strong>@suggestion.Title</strong>
                                    <span class="live-location">Best place: @suggestion.Location</span>
                                    <p class="body-copy">@suggestion.Reason</p>
                                    <div class="chip-row">
                                        @foreach (var keyword in suggestion.Keywords)
                                        {
                                            <span class="keyword-chip">@keyword</span>
                                        }
                                    </div>
                                    <div class="subtle-note">@suggestion.Impact</div>
                                </div>
                            }
                        </div>
                    }
                </section>
            }

            @if (Model.TailoredResume != null)
            {
                <section class="glass panel">
                    <div class="panel-head">
                        <div>
                            <h2>3. Updated Resume Draft</h2>
                            <p class="body-copy">This is the improved draft based on your uploaded resume and job details.</p>
                        </div>
                    </div>

                    <div class="stats-grid">
                        <div class="info-card metric @ScoreTone(Model.OptimizedATSScore)">
                            <strong>@Model.OptimizedATSScore</strong>
                            <div class="body-copy">Updated ATS score</div>
                        </div>
                        <div class="info-card metric">
                            <strong>@Model.TailoredResume.ATSKeywords.Count</strong>
                            <div class="body-copy">Matched keywords</div>
                        </div>
                    </div>

                    <div class="dual-grid" style="margin-top:1rem;">
                        <div class="info-card">
                            <div class="card-title">@Model.TailoredResume.Headline</div>
                            <p class="body-copy">@Model.TailoredResume.ProfessionalSummary</p>
                        </div>
                        <div class="info-card">
                            <div class="card-title">Highlights</div>
                            <ul>
                                @foreach (var item in Model.TailoredResume.CompanyFitHighlights)
                                {
                                    <li>@item</li>
                                }
                            </ul>
                        </div>
                    </div>

                    <div class="dual-grid" style="margin-top:1rem;">
                        <div class="info-card">
                            <div class="card-title">Keywords</div>
                            <div class="chip-row">
                                @foreach (var keyword in Model.TailoredResume.ATSKeywords)
                                {
                                    <span class="keyword-chip">@keyword</span>
                                }
                            </div>
                        </div>
                        <div class="info-card">
                            <div class="card-title">Updated Bullets</div>
                            <ul>
                                @foreach (var bullet in Model.TailoredResume.RewrittenBullets)
                                {
                                    <li>@bullet</li>
                                }
                            </ul>
                        </div>
                    </div>

                    <div class="info-card" style="margin-top:1rem;">
                        <div class="card-title">Resume Preview</div>
                        <div class="preview-box" style="margin-top:1rem;">@Model.TailoredResume.FullResumeDraft</div>
                        <div class="button-row">
                            <form method="post">
                                <button class="btn-main" type="submit" name="action" value="exportText">Export Plain Text</button>
